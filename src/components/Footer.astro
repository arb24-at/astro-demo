---
import CertificationBadges from "./CertificationBadges.astro";
import { legalNavigation, mainNavigation } from "../data/navigation";
import { siteConfig } from "../data/site";

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const toHref = (path: string) => `${base}${path}`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <section>
        <h2 class="footer-title">{siteConfig.shortName}</h2>
        <p>
          IT-Service fuer Privatkunden und Unternehmen in Berlin mit Vor-Ort-Hilfe, klaren
          Prozessen und Fokus auf Datensicherheit.
        </p>
        <p>
          Kontakt: <a href={siteConfig.contact.phoneHref}>{siteConfig.contact.phoneDisplay}</a> |
          <a href={`mailto:${siteConfig.contact.email}`}> {siteConfig.contact.email}</a>
        </p>
      </section>

      <section>
        <h2 class="footer-title">Leistungen</h2>
        <ul class="footer-links">
          {mainNavigation.map((item) => (
            <li><a href={toHref(item.href)}>{item.label}</a></li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="footer-title">Berlin-Bezirke</h2>
        <ul class="footer-links">
          {siteConfig.serviceDistricts.slice(0, 6).map((district) => (
            <li>{district}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="footer-title">Zertifizierungen</h2>
        <CertificationBadges />
      </section>
    </div>

    <div class="footer-note">
      <span>© {year} {siteConfig.shortName}. Alle Rechte vorbehalten.</span>
      <span>
        {legalNavigation.map((item, index) => (
          <>
            <a href={toHref(item.href)}>{item.label}</a>
            {index < legalNavigation.length - 1 ? " | " : ""}
          </>
        ))}
      </span>
    </div>
  </div>
</footer>
