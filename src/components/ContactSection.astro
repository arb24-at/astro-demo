---
import { siteConfig } from "../data/site";
---

<section class="section" id="kontakt">
  <div class="container">
    <div class="contact-slab">
      <section class="contact-intro">
        <span class="eyebrow" style="background: rgba(255,255,255,0.12); color: #e2e8f0;">Kontakt</span>
        <h2 class="section-title" style="margin-top: 0.7rem; color: #fff;">
          Sie benoetigen schnelle IT-Hilfe in Berlin?
        </h2>
        <p>
          Vereinbaren Sie jetzt Ihren Termin oder kontaktieren Sie unsere IT-Notaufnahme fuer
          dringende Stoerungen.
        </p>
        <div class="btn-row" style="margin-top: 1rem;">
          <a class="btn btn-primary" href={siteConfig.contact.phoneHref}>Jetzt Termin vereinbaren</a>
          <a class="btn btn-secondary" href={siteConfig.contact.phoneHref}>IT-Notaufnahme kontaktieren</a>
        </div>
        <div class="contact-meta" style="margin-top: 1rem;">
          <article class="card">
            <h3>Telefon</h3>
            <p><a href={siteConfig.contact.phoneHref}>{siteConfig.contact.phoneDisplay}</a></p>
          </article>
          <article class="card">
            <h3>E-Mail</h3>
            <p><a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></p>
          </article>
        </div>
      </section>

      <section class="contact-form-wrap">
        <h3 style="margin-top: 0;">Kurzanfrage senden</h3>
        <p style="color: var(--ink-700);">
          Diese Konzeptseite verwendet ein statisches Formular. Das Backend kann spaeter direkt
          angebunden werden.
        </p>
        <p class="operator-language-note">
          Unser Operator begleitet Sie aktuell auf Englisch - freundlich, ruhig und Schritt fuer
          Schritt. Sie koennen Ihr Anliegen trotzdem ganz entspannt senden; wir halten den Ablauf
          klar und unkompliziert.
        </p>
        <form>
          <div class="form-group">
            <label for="name">Name</label>
            <input id="name" type="text" name="name" placeholder="Ihr Name" />
          </div>
          <div class="form-group">
            <label for="email">E-Mail</label>
            <input id="email" type="email" name="email" placeholder="Ihre E-Mail-Adresse" />
          </div>
          <div class="form-group">
            <label for="anliegen">Anliegen</label>
            <textarea
              id="anliegen"
              name="anliegen"
              rows="5"
              placeholder="Beschreiben Sie kurz Ihr Problem oder Ihr Vorhaben"
            />
          </div>
          <button class="btn btn-primary" type="button" style="width: 100%;">Anfrage vorbereiten</button>
        </form>
      </section>
    </div>
  </div>
</section>
