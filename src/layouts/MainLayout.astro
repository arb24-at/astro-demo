---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../data/site";
import { withBase } from "../utils/withBase";

type Props = {
  title: string;
  description?: string;
  canonicalPath?: string;
};

const {
  title,
  description = siteConfig.defaultDescription,
  canonicalPath = ""
} = Astro.props;

const isExternalCanonical =
  canonicalPath.startsWith("http://") || canonicalPath.startsWith("https://");
const normalizedCanonicalPath = isExternalCanonical
  ? canonicalPath
  : withBase(canonicalPath);
const canonicalUrl = isExternalCanonical
  ? normalizedCanonicalPath
  : new URL(normalizedCanonicalPath, Astro.site ?? "https://www.berlin-tech-support.de")
      .toString();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
